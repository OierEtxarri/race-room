{
  "name": "garmin-connect",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "wait-on http://127.0.0.1:8787/api/health && vite",
    "dev:web:mobile": "wait-on http://127.0.0.1:8787/api/health && vite --host 0.0.0.0 --port 5173",
    "dev:api": "tsx watch server/index.ts",
    "dev:mobile": "concurrently -k \"npm:dev:api\" \"npm:dev:web:mobile\"",
    "start:api": "tsx server/index.ts",
    "build": "tsc -b && vite build",
    "check": "tsc -b",
    "lint": "tsc -b",
    "preview": "vite preview",
    "capture:readme": "wait-on http://127.0.0.1:5182 && node scripts/capture-readme-screenshots.mjs",
    "mcp:garmin": "tsx server/run-garmin-mcp.ts",
    "mcp:garmin:setup": "tsx server/run-garmin-mcp-setup.ts",
    "garmin:python:install": "python3 -m venv .venv-garmin && ./.venv-garmin/bin/pip install --upgrade pip garminconnect",
    "garmin:python:setup": "tsx server/run-garmin-python-setup.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "boneyard-js": "^1.6.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "leaflet": "^1.9.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-leaflet": "^5.0.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/express": "^5.0.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "playwright": "^1.59.1",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": {
      "zod": "4.1.12"
    },
    "eslint-plugin-react-hooks": {
      "zod": "4.1.12"
    },
    "zod-validation-error": {
      "zod": "4.1.12"
    }
  }
}
